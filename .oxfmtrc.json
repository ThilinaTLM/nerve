{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "sortImports": false,
  "sortTailwindcss": false,
  "sortPackageJson": false,
  "jsdoc": false,
  "ignorePatterns": ["pnpm-lock.yaml"],
  "svelte": {
    "allowShorthand": true,
    "indentScriptAndStyle": false,
    "sortOrder": "none"
  }
}
