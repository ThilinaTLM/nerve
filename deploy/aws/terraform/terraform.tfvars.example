aws_region  = "us-east-1"
name_prefix = "nerve-sandbox-dev"

vpc_id             = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_ids  = ["subnet-public-a", "subnet-public-b"]
private_subnet_ids = ["subnet-private-a", "subnet-private-b"]

manager_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/nerve-sandbox-manager:dev"
agent_image   = "123456789012.dkr.ecr.us-east-1.amazonaws.com/nerve-sandbox-agent:dev"

# Store actual values in AWS Secrets Manager or SSM Parameter Store.
database_url_secret_arn          = "arn:aws:secretsmanager:us-east-1:123456789012:secret:nerve/database-url"
api_key_secret_arn               = "arn:aws:secretsmanager:us-east-1:123456789012:secret:nerve/manager-api-key"
secret_encryption_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:nerve/manager-secret-key"

# For private-only deployments, set alb_internal=true and point DNS/auth at the ALB.
alb_internal       = false
alb_ingress_cidrs  = ["203.0.113.0/24"]
alb_certificate_arn = null

# Cloud Map is recommended for private sandbox -> manager websocket callbacks.
enable_cloud_map        = false
cloud_map_namespace_id  = null
cloud_map_namespace_name = null
cloud_map_service_name  = "sandbox-manager"

create_efs         = true
efs_root_directory = "/"

manager_desired_count = 1
sandbox_assign_public_ip = false

tags = {
  Environment = "dev"
}
