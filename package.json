{
  "name": "nerve",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "desktop": "pnpm --filter @nerve/desktop dev",
    "dev": "pnpm --filter @nerve/orchestrator dev",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "pnpm -r --if-present test"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.78.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
