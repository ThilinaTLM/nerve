{
  "name": "nerve",
  "version": "0.1.0-alpha.1",
  "private": true,
  "author": "ThilinaTLM",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "cli": "pnpm --filter @nerve/cli dev --",
    "daemon": "pnpm --filter @nerve/orchestrator dev",
    "desktop": "pnpm --filter @nerve/desktop dev",
    "dev": "pnpm --filter @nerve/orchestrator dev",
    "debug:agent-tools": "tsx scripts/debug-agent-tools.ts",
    "serve": "pnpm --filter @nerve/cli dev -- serve",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "pnpm -r --if-present test",
    "release:build": "pnpm --filter @nerve/shared build && pnpm --filter @nerve/agent build && pnpm --filter @nerve/tools build && pnpm --filter @nerve/web build && pnpm --filter @nerve/orchestrator build && node scripts/copy-web-dist-to-orchestrator.mjs && pnpm --filter @nerve/cli build && pnpm --filter @nerve/desktop build",
    "release:pack:npm": "pnpm release:build && node scripts/pack-npm.mjs",
    "release:desktop:linux": "pnpm --filter @nerve/desktop package:linux && pnpm release:checksums",
    "release:checksums": "node scripts/checksums.mjs",
    "release:verify-tag": "node scripts/verify-release-tag.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.79.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
