{
  "name": "nerve",
  "version": "0.1.0-alpha.1",
  "private": true,
  "author": "ThilinaTLM",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:deps": "pnpm --filter @nerve/shared --filter @nerve/agent --filter @nerve/tools build",
    "check": "pnpm -r check",
    "lint": "biome check . && pnpm lint:ts-file-lines",
    "lint:ts-file-lines": "node scripts/check-typescript-file-lines.mjs",
    "format": "biome format --write .",
    "test": "pnpm -r --if-present test",
    "desktop": "pnpm --filter @nerve/desktop dev --",
    "desktop:remote-enabled": "pnpm desktop -- --host 0.0.0.0 --allow-remote --mobile-https",
    "desktop:fast": "pnpm --filter @nerve/desktop start",
    "desktop:build": "pnpm run build:deps && pnpm --filter @nerve/web build && pnpm --filter @nerve/orchestrator build && node scripts/copy-web-dist-to-orchestrator.mjs && pnpm --filter @nerve/desktop build",
    "desktop:check": "pnpm --filter @nerve/desktop check",
    "desktop:install": "pnpm --filter @nerve/desktop icons && node scripts/install-desktop.mjs install --pnpm pnpm",
    "desktop:uninstall": "node scripts/install-desktop.mjs uninstall --pnpm pnpm",
    "dev": "pnpm run build:deps && pnpm --parallel --stream --filter @nerve/orchestrator --filter @nerve/web dev",
    "web": "pnpm run build:deps && pnpm --filter @nerve/web dev",
    "daemon": "pnpm run build:deps && pnpm --filter @nerve/orchestrator dev",
    "cli": "pnpm run build:deps && pnpm --filter @nerve/cli dev --",
    "serve": "pnpm run build:deps && pnpm --filter @nerve/cli dev -- serve --open",
    "release:build": "pnpm --filter @nerve/shared build && pnpm --filter @nerve/agent build && pnpm --filter @nerve/tools build && pnpm --filter @nerve/web build && pnpm --filter @nerve/orchestrator build && node scripts/copy-web-dist-to-orchestrator.mjs && pnpm --filter @nerve/cli build && pnpm --filter @nerve/desktop build",
    "release:pack:npm": "pnpm release:build && node scripts/pack-npm.mjs",
    "release:desktop:linux": "pnpm --filter @nerve/desktop package:linux && pnpm release:checksums",
    "release:checksums": "node scripts/checksums.mjs",
    "release:verify-tag": "node scripts/verify-release-tag.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.79.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
