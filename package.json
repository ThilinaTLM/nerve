{
  "name": "nerve",
  "version": "0.7.0",
  "private": true,
  "author": "ThilinaTLM",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "fix": "oxfmt && eslint . --fix && oxfmt",
    "check": "oxfmt --check && eslint . && pnpm -r check",
    "test": "pnpm -r --if-present test",
    "dev": "pnpm --filter @nervekit/contracts --filter @nervekit/agent-runtime --filter @nervekit/agent-tools build && pnpm --parallel --stream --filter @nervekit/orchestrator --filter @nervekit/workbench-app dev",
    "dev:ui": "pnpm --filter @nervekit/contracts --filter @nervekit/agent-runtime --filter @nervekit/agent-tools build && pnpm --filter @nervekit/workbench-app dev",
    "dev:sandbox": "pnpm --filter @nervekit/contracts build && pnpm --parallel --stream --filter @nervekit/sandbox-manager --filter @nervekit/sandbox-manager-app dev",
    "build-image:sandbox-agent": "node scripts/build-sandbox-agent-image.mjs",
    "build-image:sandbox-manager": "node scripts/build-sandbox-manager-image.mjs",
    "desktop": "pnpm --filter @nervekit/desktop-shell dev --",
    "desktop:remote-enabled": "pnpm desktop -- --host 0.0.0.0 --allow-remote --mobile-https",
    "release:build": "pnpm --filter @nervekit/contracts build && pnpm --filter @nervekit/agent-runtime build && pnpm --filter @nervekit/agent-tools build && pnpm --filter @nervekit/workbench-ui build && pnpm --filter @nervekit/sandbox-manager-app build && pnpm --filter @nervekit/sandbox-manager build && node scripts/copy-sandbox-manager-app-dist-to-manager.mjs && pnpm --filter @nervekit/workbench-app build && pnpm --filter @nervekit/orchestrator build && node scripts/copy-workbench-app-dist-to-orchestrator.mjs && pnpm --filter @nervekit/desktop-shell build",
    "release:verify-tag": "node scripts/verify-release-tag.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "eslint-plugin-svelte": "3.20.0",
    "globals": "17.7.0",
    "oxfmt": "0.58.0",
    "svelte": "5.56.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
