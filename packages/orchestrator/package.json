    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.78.1",
    "@hono/node-server": "1.19.5",
    "@nerve/agent": "workspace:*",
    "@nerve/shared": "workspace:*",
    "@nerve/tools": "workspace:*",
    "hono": "4.10.5",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/ws": "8.18.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
