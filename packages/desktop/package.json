{
  "name": "@nerve/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "start": "electron .",
    "dev": "pnpm --filter @nerve/web build && pnpm --filter @nerve/orchestrator build && pnpm --filter @nerve/desktop build && electron ."
  },
  "dependencies": {
    "@nerve/orchestrator": "workspace:*",
    "@nerve/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "electron": "^42.0.0",
    "typescript": "5.9.3"
  }
}
