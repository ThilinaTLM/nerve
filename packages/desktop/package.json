{
  "name": "@nerve/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b && cp src/preload.cjs dist/preload.cjs",
    "check": "tsc -b --pretty false",
    "start": "node scripts/start-electron.mjs",
    "dev": "pnpm --filter @nerve/web build && pnpm --filter @nerve/orchestrator build && pnpm --filter @nerve/desktop build && node scripts/start-electron.mjs"
  },
  "dependencies": {
    "@nerve/orchestrator": "workspace:*",
    "@nerve/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.15.0",
    "sharp": "^0.34.5",
    "typescript": "5.9.3"
  }
}
