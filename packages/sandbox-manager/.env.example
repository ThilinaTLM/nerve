# Sandbox Manager local development settings.
# Copy this file to .env in this directory and adjust values for your machine.

# Local manager bind address. Use 0.0.0.0 so Docker containers can call back to it.
NERVE_SANDBOX_MANAGER_HOST=0.0.0.0
NERVE_SANDBOX_MANAGER_PORT=7869
NERVE_SANDBOX_MANAGER_ALLOW_REMOTE_BIND=true
NERVE_SANDBOX_MANAGER_MODE=development

# Container runtime backend for locally launched sandboxes.
# Allowed values: auto, docker, podman. Auto tries Docker first, then Podman;
# this is useful on Windows 11 + WSL systems where Podman is available but Docker is not.
NERVE_SANDBOX_MANAGER_BACKEND=auto

# Runtime materialization root for local container bind mounts.
# Defaults to ~/.nerve/sandbox-manager when omitted.
# NERVE_SANDBOX_MANAGER_STORAGE_DIR=/home/you/.nerve/sandbox-manager

# PostgreSQL primary storage.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
NERVE_SANDBOX_MANAGER_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/nerve
NERVE_SANDBOX_MANAGER_DATABASE_SSL=false

# Development-only: allows secret records without an encryption key.
# Production should set NERVE_SANDBOX_MANAGER_SECRET_ENCRYPTION_KEY instead.
NERVE_SANDBOX_MANAGER_ALLOW_CLEARTEXT_SECRETS=true
# NERVE_SANDBOX_MANAGER_SECRET_ENCRYPTION_KEY=
# NERVE_SANDBOX_MANAGER_SECRET_ENCRYPTION_KEY_REF=local-dev

# Optional API key for local UI/API auth.
NERVE_SANDBOX_MANAGER_API_KEY=dev-key

# URL that sandbox containers use to call back to the manager.
# Linux Docker bridge default:
NERVE_SANDBOX_MANAGER_PUBLIC_URL=http://172.17.0.1:7869
# Docker Desktop alternative:
# NERVE_SANDBOX_MANAGER_PUBLIC_URL=http://host.docker.internal:7869

# UI/static serving.
NERVE_SANDBOX_MANAGER_SERVE_WEB_UI=true
