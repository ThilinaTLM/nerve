# Committed default environment for local development (`pnpm dev`, `pnpm dev:sandbox`).
# Loaded before `.env`, so a local `.env` and real environment variables both
# override anything set here. Do not put secrets in this file.

# The manager must listen beyond loopback for bridge-networked local runtimes.
# Callback URLs and container networking are selected for the effective backend
# and host platform. Set NERVE_SANDBOX_MANAGER_PUBLIC_URL in `.env` only for a
# custom network or externally reachable manager address.
NERVE_SANDBOX_MANAGER_HOST=0.0.0.0
NERVE_SANDBOX_MANAGER_ALLOW_REMOTE_BIND=true
NERVE_SANDBOX_MANAGER_MODE=development

# Verbose structured logging while developing. The manager also propagates this
# level to the sandbox containers it launches (via NERVE_SANDBOX_AGENT_LOG_LEVEL)
# unless a sandbox pins its own observability.logLevel.
NERVE_SANDBOX_MANAGER_LOG_LEVEL=debug
