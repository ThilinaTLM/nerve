{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["svelte", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@nervekit/ui-kit/core/utils": ["./src/lib/core/utils.ts"],
      "@nervekit/ui-kit/core/*": ["./src/lib/core/*"],
      "@nervekit/ui-kit/components/ui/*": ["./src/lib/components/ui/*/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "svelte.config.js"]
}
