{
  "name": "@nervekit/ui-kit",
  "version": "0.7.0",
  "description": "Contract-free Nerve UI primitives, renderers, utilities, and theme styles.",
  "private": true,
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "exports": {
    ".": "./src/lib/index.ts",
    "./styles/app.css": "./src/styles/app.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/base.css": "./src/styles/base.css",
    "./styles/animation.css": "./src/styles/animation.css",
    "./styles/components.css": "./src/styles/components.css",
    "./core/utils": "./src/lib/core/utils.ts",
    "./core/api/client": "./src/lib/core/api/client.ts",
    "./core/clipboard": "./src/lib/core/clipboard.ts",
    "./core/components/Markdown.svelte": "./src/lib/core/components/Markdown.svelte",
    "./core/components/PlainText.svelte": "./src/lib/core/components/PlainText.svelte",
    "./core/components/markdown-render": "./src/lib/core/components/markdown-render.ts",
    "./core/highlight/highlight": "./src/lib/core/highlight/highlight.ts",
    "./core/terminal/ansi": "./src/lib/core/terminal/ansi.ts",
    "./core/notify": "./src/lib/core/notify.ts",
    "./core/utils/*": "./src/lib/core/utils/*.ts",
    "./components/ui/*": "./src/lib/components/ui/*/index.ts"
  },
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "clsx": "^2.1.1",
    "svelte": "5.56.3",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fontsource/iosevka": "^5.2.5",
    "@fontsource/outfit": "^5.2.6",
    "@shikijs/core": "^4.1.0",
    "@shikijs/engine-javascript": "^4.1.0",
    "@shikijs/langs": "^4.1.0",
    "@shikijs/themes": "^4.1.0",
    "@tanstack/svelte-virtual": "^3.13.29",
    "bits-ui": "^2.18.1",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn-svelte": "^1.4.1",
    "shiki": "^4.1.0",
    "svelte-sonner": "^1.1.1",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "svelte-check": "4.3.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "tailwindcss": "4.3.1",
    "vite": "8.0.16"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
