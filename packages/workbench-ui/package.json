{
  "name": "@nervekit/workbench-ui",
  "version": "0.11.0",
  "description": "App-neutral Svelte workbench features, components, and styles.",
  "private": true,
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "exports": {
    ".": "./src/lib/index.ts",
    "./components/settings": "./src/lib/components/settings/index.ts",
    "./components/workbench": "./src/lib/components/workbench/index.ts",
    "./components/navigator": "./src/lib/components/navigator/index.ts",
    "./components/conversation": "./src/lib/components/conversation/index.ts",
    "./components/file": "./src/lib/components/file/index.ts",
    "./git": "./src/lib/git/index.ts",
    "./git/*": "./src/lib/git/*",
    "./tasks": "./src/lib/tasks/index.ts",
    "./tasks/*": "./src/lib/tasks/*",
    "./state": "./src/lib/state/index.ts",
    "./context": "./src/lib/context.svelte.ts",
    "./components/transcript/TranscriptList.svelte": "./src/lib/components/transcript/TranscriptList.svelte",
    "./components/transcript/TranscriptRow.svelte": "./src/lib/components/transcript/TranscriptRow.svelte",
    "./components/ConversationPaneLayout.svelte": "./src/lib/components/ConversationPaneLayout.svelte",
    "./components/composer/ComposerShell.svelte": "./src/lib/components/composer/ComposerShell.svelte",
    "./components/composer/ComposerToolbar.svelte": "./src/lib/components/composer/ComposerToolbar.svelte",
    "./components/composer/ComposerEditor.svelte": "./src/lib/components/composer/ComposerEditor.svelte",
    "./components/composer/ComposerModelPicker.svelte": "./src/lib/components/composer/ComposerModelPicker.svelte",
    "./components/composer/ContextProgressBadge.svelte": "./src/lib/components/composer/ContextProgressBadge.svelte",
    "./components/composer/ContextUsageChip.svelte": "./src/lib/components/composer/ContextUsageChip.svelte",
    "./components/composer/TodoProgressChip.svelte": "./src/lib/components/composer/TodoProgressChip.svelte",
    "./tools/components/ToolCallCard.svelte": "./src/lib/tools/components/ToolCallCard.svelte",
    "./tools/*.svelte": "./src/lib/tools/*.svelte",
    "./tools/*": "./src/lib/tools/*.ts",
    "./core/utils/model": "./src/lib/core/utils/model.ts"
  },
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lucide/svelte": "^1.17.0",
    "@nervekit/contracts": "workspace:*",
    "@nervekit/ui-kit": "workspace:*",
    "svelte": "5.56.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "svelte-check": "4.3.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vite": "8.0.16"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
